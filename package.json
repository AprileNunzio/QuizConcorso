{
  "name": "quiz-concorso",
  "productName": "Quiz_Concorso",
  "description": "Un'applicazione desktop ultra-moderna progettata per lo studio e la preparazione a qualsiasi concorso pubblico.",
  "author": "NunzioTech",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:dev": "tsc -p electron/tsconfig.json && concurrently \"npm run dev\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder --publish never",
    "build:local": "node scripts/build-local.mjs",
    "build:publish": "npm version patch && git push && git push --tags",
    "start": "npm run electron:dev"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.nunziotech.quizconcorso",
    "productName": "Quiz_Concorso",
    "copyright": "Copyright © 2026 NunzioTech",
    "publish": [
      {
        "provider": "github",
        "owner": "AprileNunzio",
        "repo": "QuizConcorso"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "include": "build/installer.nsh"
    }
  }
}
